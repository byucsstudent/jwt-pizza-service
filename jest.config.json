{
  "setupFilesAfterEnv": [
    "<rootDir>/src/setupTests.js"
  ],
  "collectCoverage": true,
  "coverageReporters": [
    "json-summary",
    "text",
    "text-summary"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 30,
      "functions": 70,
      "lines": 80,
      "statements": 80
    }
  }
}